# Copier ce fichier en .env et remplir avec des valeurs fortes.
# Ne jamais committer le fichier .env (il est dans .gitignore).

# Mot de passe root MySQL (production)
MYSQL_ROOT_PASSWORD=change-me-use-a-strong-password

# Nom de la base
MYSQL_DATABASE=ecommercedb

# Variables Spring (profil prod) — utilisées par docker-compose.prod.yml
DB_URL=jdbc:mysql://mysql:3306/ecommercedb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
# Doit être identique à MYSQL_ROOT_PASSWORD
DB_PASSWORD=change-me-use-a-strong-password

# Image Docker (optionnel — pour tirer depuis GHCR au lieu de build local)
# BACKEND_IMAGE=ghcr.io/mohammedelouaqqad/ecommerce-backend-devops:latest
